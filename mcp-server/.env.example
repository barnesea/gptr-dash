# OpenAI API key for GPT models (required)
OPENAI_API_KEY=open-api-key-here

# Tavily API key for web search (required)
TAVILY_API_KEY=tavily-api-key-here

# GPT Researcher configuration
# Embedding model
EMBEDDING=openai:text-embedding-3-small
# LLM for strategic research
STRATEGIC_LLM=openai:gpt-4o-mini # To increase speed, use gpt-4o-mini

# Maximum number of research iterations
# (To increase speed, use 2)
MAX_ITERATIONS=2

# Optional example: Anthropic API key if using Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MCP server configuration
LOG_LEVEL=INFO
MCP_TRANSPORT=sse
MCP_PORT=8001 

# Local LLM defaults via llama-swap. If FAST_LLM, SMART_LLM, and
# STRATEGIC_LLM are unset, GPT Researcher will call ${LLAMA_SWAP_URL}/running
# and use the currently running model for all three roles.
LLAMA_SWAP_URL=http://localhost:8080
LLAMA_SWAP_ENABLED=true
LLAMA_SWAP_TIMEOUT=1.0
